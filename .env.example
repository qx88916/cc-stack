# ============================================
# CABCONNECT MONOREPO - ENVIRONMENT VARIABLES
# ============================================
# Each app has its own .env file. Copy this as a reference.
# App-specific .env.example files are in each app directory.
#
# apps/backend/.env        — Backend API
# apps/admin/.env.local    — Admin Dashboard
# apps/passenger/.env      — Passenger App
# apps/driver/.env         — Driver App
# ============================================

# =====================
# BACKEND (apps/backend/.env)
# =====================
MONGODB_URI=mongodb://127.0.0.1:27017/ridehailing
PORT=5000
NODE_ENV=development
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_64_CHAR_HEX_STRING
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:19006
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=your_resend_api_key_here
RESEND_SENDER_EMAIL=noreply@yourdomain.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# REDIS_URL=redis://localhost:6379
# GOOGLE_MAPS_API_KEY=
ADMIN_DEFAULT_EMAIL=admin@cabconnect.com
ADMIN_DEFAULT_PASSWORD=Admin@123456

# =====================
# ADMIN (apps/admin/.env.local)
# =====================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=CabConnect Admin

# =====================
# PASSENGER APP (apps/passenger/.env)
# =====================
EXPO_PUBLIC_PLACES_API_KEY=your_google_places_api_key
EXPO_PUBLIC_DIRECTIONS_API_KEY=your_google_directions_api_key
EXPO_PUBLIC_GEOAPIFY_API_KEY=your_geoapify_api_key
# EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# =====================
# DRIVER APP (apps/driver/.env)
# =====================
# EXPO_PUBLIC_API_URL=http://localhost:5000
# EXPO_PUBLIC_GEOAPIFY_API_KEY=your_key
# EXPO_PUBLIC_DIRECTIONS_API_KEY=your_key
