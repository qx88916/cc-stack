**Store Structure:**
```typescript
// store/savedPlacesStore.ts
interface SavedPlace {
  type: 'home' | 'work' | 'custom';
  label: string;
  address: string;
  coordinates: { lat: number; lng: number };
}

export const useSavedPlacesStore = create<{
  places: Record<string, SavedPlace>;
  setPlace: (type: string, place: SavedPlace) => Promise<void>;
  deletePlace: (type: string) => Promise<void>;
}>((set) => ({
  places: {},
  
  setPlace: async (type, place) => {
    // Save to backend
    await fetchAPI('/user/saved-places', {
      method: 'POST',
      body: JSON.stringify({ type, place })
    });
    
    // Update local state
    set((state) => ({
      places: { ...state.places, [type]: place }
    }));
  },
  
  deletePlace: async (type) => {
    await fetchAPI(`/user/saved-places/${type}`, { method: 'DELETE' });
    set((state) => {
      const { [type]: _, ...rest } = state.places;
      return { places: rest };
    });
  }
}));
```

