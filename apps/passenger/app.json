{
  "expo": {
    "name": "Cab Connect",
    "slug": "cab-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cabconnect",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cabconnect.passenger"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cabconnect.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#10b981",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "resizeMode": "cover",
          "backgroundColor": "#10b981",
          "dark": {
            "image": "./assets/images/splash.png",
            "backgroundColor": "#10b981",
            "resizeMode": "cover"
          },
          "android": {
            "backgroundColor": "#10b981",
            "image": "./assets/images/splash.png",
            "resizeMode": "cover"
          },
          "ios": {
            "backgroundColor": "#10b981",
            "image": "./assets/images/splash.png",
            "resizeMode": "cover"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd807cb2-ef90-469d-ad6f-a1beb8be31ab"
      }
    }
  }
}