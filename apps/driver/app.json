{
  "expo": {
    "name": "FijiCabConnect Driver",
    "slug": "fijicabconnect-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "driverapp",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fijicabconnect.driver"
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.fijicabconnect.driver"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FijiCabConnect Driver needs your location to send ride requests.",
          "locationAlwaysPermission": "FijiCabConnect Driver needs background location to receive rides while offline.",
          "locationWhenInUsePermission": "FijiCabConnect Driver needs your location to show you nearby rides.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#f59e0b"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FijiCabConnect Driver accesses your photos to update your profile picture."
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2e06f3d0-2717-414d-878a-e5a19aebebe8"
      }
    }
  }
}
