# ============================================
# CABCONNECT BACKEND - ENVIRONMENT VARIABLES
# ============================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in all values marked as REQUIRED
# 3. NEVER commit .env to git (it's in .gitignore)
#
# ============================================

# --------------------------------------------
# DATABASE
# --------------------------------------------
# REQUIRED: MongoDB connection string
# Local dev: mongodb://127.0.0.1:27017/ridehailing
# Production: Get from MongoDB Atlas
MONGODB_URI=mongodb://127.0.0.1:27017/ridehailing

# --------------------------------------------
# SERVER
# --------------------------------------------
# REQUIRED: Port for Express server (default: 5000)
PORT=5000

# REQUIRED: Environment (development, staging, production)
NODE_ENV=development

# --------------------------------------------
# SECURITY
# --------------------------------------------
# REQUIRED: JWT secret for token signing (MUST be 32+ characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# CRITICAL: Change this in production! Default is INSECURE.
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_64_CHAR_HEX_STRING

# OPTIONAL: Allowed origins for CORS (comma-separated)
# Development: http://localhost:8081,http://localhost:19006
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081,http://localhost:19006

# --------------------------------------------
# EMAIL SERVICE (BREVO)
# --------------------------------------------
# REQUIRED: Brevo API key for sending emails
# Get from: https://app.brevo.com/settings/keys/api
# Should start with: xkeysib-...
BREVO_API_KEY=your_brevo_api_key_here

# REQUIRED: Verified sender email for Brevo
# 
# CRITICAL: This email MUST be verified in your Brevo account before emails will send.
# 
# SETUP INSTRUCTIONS:
# 1. Log in to: https://app.brevo.com/settings/senders
# 2. Click "Add a sender"
# 3. Enter your email address (e.g., noreply@fijicabconnect.com)
# 4. Brevo will send a verification link to this email
# 5. Click the verification link to confirm
# 6. Once verified, copy the email address here
# 
# NOTE: Emails will NOT be sent if this sender is not verified in Brevo.
#       For testing, you can use the mock OTP (see OTP_MOCK_CODE below).
# 
# RECOMMENDATION: Use a subdomain you control (e.g., noreply@fijicabconnect.com)
#                 NOT a personal Gmail/Yahoo address (higher spam risk)
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# --------------------------------------------
# EMAIL SERVICE (RESEND - BACKUP)
# --------------------------------------------
# OPTIONAL: Resend API key for email failover
# Get from: https://resend.com/api-keys
# Should start with: re_...
# Used as backup when Brevo fails
RESEND_API_KEY=your_resend_api_key_here

# OPTIONAL: Verified sender email for Resend
# Must verify domain in Resend dashboard
# Or use: onboarding@resend.dev for testing
RESEND_SENDER_EMAIL=noreply@yourdomain.com

# --------------------------------------------
# EMAIL SERVICE - RESEND (BACKUP)
# --------------------------------------------
# REQUIRED: Resend API key for backup email sending
# Get from: https://resend.com/api-keys
# Should start with: re_...
RESEND_API_KEY=your_resend_api_key_here

# REQUIRED: Verified sender email for Resend
# Must be verified in your Resend account
# Can use default testing domain: onboarding@resend.dev
RESEND_SENDER_EMAIL=noreply@yourdomain.com

# --------------------------------------------
# CLOUDINARY (Profile Photo Storage)
# --------------------------------------------
# REQUIRED for profile photo uploads
# Sign up free: https://cloudinary.com (25GB free)
# Get credentials from: https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --------------------------------------------
# GOOGLE MAPS (OPTIONAL - for backend geocoding)
# --------------------------------------------
# OPTIONAL: Google Maps API key for backend services
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=

# --------------------------------------------
# OTP CONFIGURATION
# --------------------------------------------
# OPTIONAL: Mock OTP code for development/testing only
# WARNING: Only works when NODE_ENV=development
# When set, all OTPs will be this value instead of random
# OTP_MOCK_CODE=123456

# --------------------------------------------
# FARE CONFIGURATION (OPTIONAL)
# --------------------------------------------
# Base fare in local currency (default: 2.5)
FARE_BASE=2.5

# Cost per kilometer (default: 1.2)
FARE_PER_KM=1.2

# Cost per minute (default: 0.15)
FARE_PER_MIN=0.15

# Currency code (default: USD)
FARE_CURRENCY=USD

# --------------------------------------------
# REDIS (OPTIONAL - recommended for production)
# --------------------------------------------
# Redis connection URL for OTP storage and caching
# Local: redis://localhost:6379
# Upstash: rediss://default:password@redis.upstash.io:6379
# Render: redis://red-xxx:6379
# If not set, falls back to in-memory storage (not recommended for production)
# REDIS_URL=redis://localhost:6379

# --------------------------------------------
# LOGGING (OPTIONAL)
# --------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info

# --------------------------------------------
# ADMIN CONFIGURATION
# --------------------------------------------
# REQUIRED: Default admin user credentials for seeding
# Change these before running seed script
# Use strong password in production
ADMIN_DEFAULT_EMAIL=admin@cabconnect.com
ADMIN_DEFAULT_PASSWORD=Admin@123456
